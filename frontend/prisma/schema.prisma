generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}


datasource db {
  provider = "postgresql"
}

model career_catalyst {
  id         Int       @id @default(autoincrement())
  full_name  String
  email      String
  phone      String
  department String
  year       String
  skills     String
  motivation String
  applied_on DateTime? @default(now()) @db.Timestamp(6)
}

model data_science_innovation {
  id         Int       @id @default(autoincrement())
  full_name  String
  email      String
  phone      String
  department String
  year       String
  skills     String
  motivation String
  applied_on DateTime? @default(now()) @db.Timestamp(6)
}

model event_proposals {
  id                 Int       @id @default(autoincrement())
  organizer_name     String    @db.VarChar(120)
  organizer_email    String    @db.VarChar(120)
  event_title        String    @db.VarChar(200)
  event_type         String    @db.VarChar(80)
  proposed_date      DateTime? @db.Date
  expected_attendees Int?
  venue_needed       String?   @db.VarChar(100)
  description        String?
  club_team          String?   @db.VarChar(150)
  status             String    @default("pending") @db.VarChar(20)
  submitted_on       DateTime  @default(now()) @db.Timestamp(6)
}

model hackronyx_willingness {
  id           Int      @id @default(autoincrement())
  full_name    String   @db.VarChar(120)
  email        String   @db.VarChar(120)
  department   String   @db.VarChar(120)
  mobile_no    String   @db.VarChar(20)
  submitted_at DateTime @default(now()) @db.Timestamp(6)
}

model event_registrations {
  id            Int       @id @default(autoincrement())
  event_name    String
  full_name     String
  email         String
  phone         String
  year          String
  expectations  String
  registered_on DateTime? @default(now()) @db.Timestamp(6)
}

model users {
  id       Int     @id @default(autoincrement())
  name     String
  email    String  @unique
  password String
  role     String? @default("user")
}

model web_nest_technology {
  id         Int       @id @default(autoincrement())
  full_name  String
  email      String
  phone      String
  department String
  year       String
  skills     String
  motivation String
  applied_on DateTime? @default(now()) @db.Timestamp(6)
}

// Auth.js Models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // null for Google OAuth users
  accounts      Account[]
  sessions      Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}


model site_stats {
  id    Int @id @default(autoincrement())
  views Int @default(0)
}
