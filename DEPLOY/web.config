<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <handlers>
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>

    <!-- Fallback: tell IIS that server.js IS the homepage -->
    <defaultDocument enabled="true">
      <files>
        <clear />
        <add value="server.js" />
      </files>
    </defaultDocument>

    <rewrite>
      <rules>
        <!-- Route all non-file requests through server.js -->
        <rule name="SendToNode" stopProcessing="true">
          <match url=".*" />
          <action type="Rewrite" url="server.js" />
        </rule>
      </rules>
    </rewrite>

    <iisnode
      node_env="production"
      loggingEnabled="true"
      logDirectory="iisnode"
      debuggingEnabled="false"
    />

    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment="node_modules" />
          <add segment=".next" />
          <add segment=".env" />
        </hiddenSegments>
      </requestFiltering>
    </security>

  </system.webServer>
</configuration>
