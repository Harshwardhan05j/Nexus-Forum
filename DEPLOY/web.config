<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <handlers>
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>

    <!-- Fallback: tell IIS that server.js IS the homepage -->
    <defaultDocument enabled="true">
      <files>
        <clear />
        <add value="server.js" />
      </files>
    </defaultDocument>

    <httpErrors existingResponse="PassThrough" />

    <rewrite>
      <rules>
        <!-- Serve /_next/static/ files directly from _next/static/ folder via IIS (no Node.js needed) -->
        <rule name="NextStaticFiles" stopProcessing="true">
          <match url="^_next/static/(.*)" />
          <conditions>
            <add input="{DOCUMENT_ROOT}/_next/static/{R:1}" matchType="IsFile" />
          </conditions>
          <action type="None" />
        </rule>

        <!-- Route everything else through Node.js (iisnode) -->
        <rule name="SendToNode" stopProcessing="true">
          <match url=".*" />
          <action type="Rewrite" url="server.js" />
        </rule>
      </rules>
    </rewrite>

    <iisnode
      node_env="production"
      loggingEnabled="true"
      logDirectory="iisnode"
      debuggingEnabled="false"
    />

    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment="node_modules" />
          <add segment=".next" />
          <add segment=".env" />
        </hiddenSegments>
      </requestFiltering>
    </security>

  </system.webServer>
</configuration>
